{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/upload-leads",    "dest": "/api/upload-leads.js" },
    { "src": "/api/send-emails",     "dest": "/api/send-emails.js" },
    { "src": "/api/campaign-status", "dest": "/api/campaign-status.js" },
    { "src": "/styles.css",          "dest": "/public/styles.css" },
    { "src": "/(.*)",                "dest": "/public/index.html" }
  ]
}
